{
  "entities": {
    "Portfolio": {
      "title": "Portfolio",
      "description": "Portfolio item representing documentary, photo, interview, or poster files",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Item title" },
        "category": { "type": "string", "enum": ["video", "photo", "interview", "poster"] },
        "description": { "type": "string", "description": "Detailed description or interview story" },
        "imageUrl": { "type": "string", "description": "Cover image URL or highly-compressed base64 data url" },
        "videoUrl": { "type": "string", "description": "Optional external video url (e.g., YouTube slider)" },
        "creatorAge": { "type": "integer", "description": "Age of the participant, within 20s" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "description", "imageUrl", "createdAt"]
    },
    "Notice": {
      "title": "Notice",
      "description": "Announcements and official notices",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Announcement title" },
        "content": { "type": "string", "description": "Markdown text or content detail" },
        "category": { "type": "string", "description": "Category of notice" },
        "isPublic": { "type": "boolean", "description": "Is notice visible to the public?" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "isPublic", "createdAt"]
    },
    "ProductionApplication": {
      "title": "ProductionApplication",
      "description": "Production request from individuals in their 20s wishing to record their stories",
      "type": "object",
      "properties": {
        "applicantName": { "type": "string", "description": "Name of the applicant" },
        "age": { "type": "integer", "description": "Age of the applicant" },
        "phone": { "type": "string", "description": "Phone number" },
        "email": { "type": "string", "description": "Email address" },
        "storyTitle": { "type": "string", "description": "Story theme or topic" },
        "storyDetails": { "type": "string", "description": "Elaborated context of their Cheongju story" },
        "preferredType": { "type": "string", "enum": ["video", "photo", "interview", "poster"] },
        "status": { "type": "string", "enum": ["received", "reviewed", "accepted", "declined", "contacted", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["applicantName", "age", "phone", "email", "storyTitle", "storyDetails", "preferredType", "status", "createdAt"]
    },
    "SupporterApplication": {
      "title": "SupporterApplication",
      "description": "Application to register as a Cheongju Youth Film Supporter",
      "type": "object",
      "properties": {
        "applicantName": { "type": "string", "description": "Name of the applicant" },
        "age": { "type": "integer", "description": "Age of the supporter applicant" },
        "phone": { "type": "string", "description": "Phone number" },
        "email": { "type": "string", "description": "Email address" },
        "introduction": { "type": "string", "description": "Brief bio" },
        "motive": { "type": "string", "description": "Reason for joining" },
        "instagramUrl": { "type": "string", "description": "Instagram portfolio or handle link" },
        "region": { "type": "string", "description": "Residence region of supporter" },
        "interests": { "type": "string", "description": "Volunteer interests/sections of crew" },
        "availableDays": { "type": "string", "description": "Scheduled days available for participation" },
        "status": { "type": "string", "enum": ["received", "reviewed", "accepted", "declined", "contacted", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["applicantName", "age", "phone", "email", "introduction", "motive", "status", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Q&A inquiry posted by users",
      "type": "object",
      "properties": {
        "writerName": { "type": "string", "description": "Name of inquirer" },
        "email": { "type": "string", "description": "Contact email" },
        "subject": { "type": "string", "description": "Inquiry heading" },
        "message": { "type": "string", "description": "Inquiry text content" },
        "isSecret": { "type": "boolean", "description": "Is this Inquiry locked behind password?" },
        "password": { "type": "string", "description": "Plaintext simple key for user to view their secret inquiry" },
        "reply": { "type": "string", "description": "Admin response string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["writerName", "email", "subject", "message", "isSecret", "status", "createdAt"]
    }
  },
  "firestore": {
    "/portfolios/{portfolioId}": {
      "schema": "Portfolio",
      "description": "Collection of photographic, video, poster, and interview records of Cheongju 20s"
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Chronological system notices and updates"
    },
    "/productionApplications/{applicationId}": {
      "schema": "ProductionApplication",
      "description": "Public content request inquiries (non-authed submission permitted)"
    },
    "/supporterApplications/{supporterId}": {
      "schema": "SupporterApplication",
      "description": "Public youth supporter application forms"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Public Q&S forum questions"
    }
  }
}
